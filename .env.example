# Environment Variables for Task Management App Backend

# Server Configuration (Railway sets this automatically)
PORT=3000

# Database Configuration (Use your MongoDB Atlas connection string)
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/taskmanager?retryWrites=true&w=majority

# JWT Configuration (Use a strong, random secret)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-make-it-very-long-and-random

# Frontend URL (Your Netlify app URL)
FRONTEND_URL=https://barista-task.netlify.app